APP_NAME="Risa Digital Invitation"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://invitation.wahid-elektronik.online

LOG_CHANNEL=stack
LOG_LEVEL=error

# ─── MySQL (cPanel / Proxmox) ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nama_database
DB_USERNAME=nama_user
DB_PASSWORD=password_database
# ──────────────────────────────────────────────────────────────────────────────

CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public
BROADCAST_DRIVER=log

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@invitation.wahid-elektronik.online"
MAIL_FROM_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://invitation.wahid-elektronik.online/auth/google/callback

TURNSTILE_SITE_KEY=
TURNSTILE_SITE_SECRET=
