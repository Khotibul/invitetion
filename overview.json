      "#!/usr/bin/env python3",
      "import glob, os, re",
      "",
      "TEMPLATES = glob.glob('resources/views/template/*.blade.php')",
      "BANNER = \"@include('template.partials.preview-banner')\"",
      "SKIP = ['default.blade.php']",
      "",
      "updated = []",
      "for path in sorted(TEMPLATES):",
      "fname = os.path.basename(path)"
