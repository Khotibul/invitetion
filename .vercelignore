# Tidak perlu di Vercel function bundle
node_modules
.git
tests

# Storage runtime (dibuat ulang di /tmp)
storage/logs
storage/framework/cache
storage/framework/sessions
storage/framework/views

# Dev vendor packages (sudah di-exclude dari composer --no-dev)
vendor/bin
vendor/fakerphp
vendor/laravel/sail
vendor/laravel/pint
vendor/mockery
vendor/nunomaduro
vendor/phpunit
vendor/spatie/laravel-ignition

# Source files (tidak perlu di PHP function)
resources/sass
resources/js

# Large static assets (dilayani langsung, bukan via PHP)
public/modules
