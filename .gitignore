# ── Environment ──────────────────────────────────────────────────────────────
.env*
!.env.example
.phpunit.result.cache

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/

# ── Laravel runtime ───────────────────────────────────────────────────────────
/bootstrap/cache/
/storage/*.key
# Framework cache — dibuat otomatis oleh Laravel
/storage/framework/cache/
/storage/framework/sessions/
/storage/framework/views/
/storage/logs/
# JANGAN exclude storage/app/ — file upload perlu di-commit agar tampil di hosting

# ── node_modules — tidak perlu di-push ────────────────────────────────────────
/node_modules/

# ── vendor DEV packages — tidak perlu di-push ─────────────────────────────────
# vendor/ sendiri HARUS di-push agar Vercel bisa jalan (tidak ada composer di Vercel)
/vendor/bin/
/vendor/fakerphp/
/vendor/laravel/sail/
/vendor/laravel/pint/
/vendor/mockery/
/vendor/nunomaduro/
/vendor/phpunit/
/vendor/spatie/laravel-ignition/

# ── Vite hot reload ───────────────────────────────────────────────────────────
/public/hot

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Diagnostic files (hapus setelah deploy) ───────────────────────────────────
/public/check-assets.php
/public/clear-cache.php
/public/make-storage-link.php

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
