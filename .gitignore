# ── Environment ──────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.phpunit.result.cache

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/

# ── Laravel runtime ───────────────────────────────────────────────────────────
/bootstrap/cache/
/storage/*.key
/storage/app/
/storage/framework/
/storage/logs/

# ── node_modules — tidak perlu di-push ────────────────────────────────────────
/node_modules/

# ── vendor DEV packages — tidak perlu di-push ─────────────────────────────────
