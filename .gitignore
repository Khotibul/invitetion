/vendor/bin/
/vendor/fakerphp/
/vendor/laravel/sail/
/vendor/laravel/pint/
/vendor/mockery/
/vendor/nunomaduro/
/vendor/phpunit/
/vendor/spatie/laravel-ignition/

# ── Vite hot reload ───────────────────────────────────────────────────────────
/public/hot

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Diagnostic files (hapus setelah deploy) ───────────────────────────────────
/public/check-assets.php
/public/clear-cache.php
